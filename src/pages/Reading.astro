---
import type { MarkdownInstance } from "astro";
import Layout from "../layouts/Layout.astro";

interface Book {
	status: string;
	page: string;
	description: string;
	thumbnail: string;
	thumbnail_dark: string;
	heroImage: string;
	heroImage_dark: string;
	info: string;
}

const books = Object.values(
	import.meta.glob<MarkdownInstance<Book>>("./reading/*.md", { eager: true }),
);
---

<style is:global>
@reference "../styles/global.css";
</style>

<Layout>
	<article class="flex flex-col gap-8 items-center">
		<h1 class="text-3xl self-start">Finished</h1>
		<ul class="grid gap-6 w-full">
			{books.filter(book => book.frontmatter.status === 'read').map((book) => {
			return  (
			<li class={`flex flex-col gap-2 justify-self-center`}>
				<a href={ `/reading/${book.frontmatter.page}`}  >
					<img
						alt="read"
						src={book.frontmatter.thumbnail}
						class={` w-60 h-72 self-center rounded-lg cursor-pointer transition hover:-translate-y-2 shadow-sm shadow-gray-400 dark:shadow-none`}
					/> 
				</a>
				<span class="flex justify-center"><a href={ `/reading/${book.frontmatter.page}`}>
					{book.frontmatter.description}
				</a></span>
			</li>
			)}
			)}
		</ul>
		<h1 class="text-3xl self-start">In progress</h1>
		<ul class="grid gap-6 w-full">
			{books.filter(book => book.frontmatter.status === 'in-progress').map((book) => {
			return  (
			<li class={`flex flex-col gap-2 justify-self-center`}>
				<a href={ `/reading/${book.frontmatter.page}`}  >
					<img
						alt='in-progress'
						src={book.frontmatter.thumbnail}
						class={` w-60 h-72 self-center rounded-lg cursor-pointer transition hover:-translate-y-2 shadow-sm shadow-gray-400 dark:shadow-none`}
					/> 
				</a>
				<span class="flex justify-center"><a href={ `/reading/${book.frontmatter.page}`}>
					{book.frontmatter.description}
				</a></span>
			</li>
			)}
			)}
		</ul>
		<h1 class="text-3xl self-start">Up next</h1>
		<ul class="grid gap-6 w-full">
			{books.filter(book => book.frontmatter.status === 'unread').map((book) => {
			return  (
			<li class={`flex flex-col gap-2 justify-self-center`}>
				<a href={ `/reading/${book.frontmatter.page}`}  >
					<img
						alt='completed'
						src={book.frontmatter.thumbnail}
						class={` w-60 h-72 self-center rounded-lg cursor-pointer transition hover:-translate-y-2 shadow-sm shadow-gray-400 dark:shadow-none`}
					/> 
				</a>
				<span class="flex justify-center">
					<a href={ `/reading/${book.frontmatter.page}`}>
					{book.frontmatter.description}
		</a></span>
			</li>
			)}
			)}
		</ul>
		<slot />
	</article>
</Layout>
