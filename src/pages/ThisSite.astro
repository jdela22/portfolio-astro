---
import AstroDark from "../assets/astro_dark.svg";
import AstroLight from "../assets/astro_light.svg";
import Bun from "../assets/Bun.svg";
import Biome from "../assets/biome_logo.svg";
import Shadcn from "../assets/shadcn-ui.svg";
import Tailwind from "../assets/tailwind_thumbnail.svg";
import LineItem from "../components/LineItem.astro";
import PageHeading from "../components/PageHeading.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<PageHeading>This site</PageHeading>
	<ul class="flex flex-col gap-8">
		<LineItem
			title="Astro"
			href="https://astro.build/"
			iconSrc={AstroDark.src}
			iconDarkSrc={AstroLight.src}
		/>
		<LineItem title="Bun" href="https://bun.sh/" iconSrc={Bun.src} />
		<LineItem
			title="shadcn"
			href="https://ui.shadcn.com/"
			iconSrc={Shadcn.src}
			iconClass="dark:brightness-0 dark:invert"
		/>
		<LineItem
			title="Biome"
			href="https://biomejs.dev/"
			iconSrc={Biome.src}
			iconClass="dark:brightness-0 dark:invert"
		/>
		<LineItem
			title="Tailwind"
			href="https://tailwindcss.com/"
			iconSrc={Tailwind.src}
		/>
	</ul>
</Layout>
