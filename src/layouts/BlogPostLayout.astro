---
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
---

<style is:global>
@reference "../styles/global.css";

.markdown-body {
	p {
		margin-top: 15px;
	}

	li {
		margin-top: 5px;
		list-style-type: disc;
	}

	ul {
		list-style: decimal inside;
	}

	a {
		/* @apply underline underline-offset-2 hover:text-orange-500 decoration-orange-500 outline-orange-500; */
		@apply underline underline-offset-2 hover:text-blue-900 decoration-blue-900 outline-blue-900 dark:hover:text-blue-300 dark:decoration-blue-300 dark:outline-blue-300;
	}
}
</style>

<Layout>
	<article>
		<section class="flex justify-center">
			<a href={frontmatter.info} target="_blank">
				<div class="dark:hidden">
					<img
						src={frontmatter.heroImage}
						alt="hero"
						class="hidden sm:block h-28 w-96"
					>
					<img
						src={frontmatter.thumbnail}
						alt="thumbnail"
						class="block sm:hidden h-28 w-96"
					>
				</div>
				<div class="hidden dark:block">
					<img
						src={frontmatter.heroImage_dark}
						alt="hero-dark"
						class="hidden sm:block h-28 w-96"
					>
					<img
						src={frontmatter.thumbnail_dark}
						alt="thumbnail-dark"
						class="block sm:hidden h-28 w-96"
					>
				</div>
			</a>
		</section>
		<!-- <h1>{frontmatter.title}</h1> -->
		<!-- <p>{frontmatter.description}</p> -->
		<section class="markdown-body"><slot /></section>
	</article>
</Layout>
